# === TELEGRAM ===
# Lấy token từ @BotFather trên Telegram
TELEGRAM_BOT_TOKEN=
# Lấy chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# === BINANCE ===
# Testnet: testnet.binancefuture.com | Live: binance.com → API Management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

# === LLM — chọn ít nhất 1 provider ===
# anthropic | openai | gemini | deepseek
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# === PER-MODE LLM OVERRIDE (optional) ===
# Để trống để dùng LLM_PROVIDER / LLM_MODEL mặc định
LLM_PROVIDER_SWING=
LLM_MODEL_SWING=
LLM_PROVIDER_INTRADAY=
LLM_MODEL_INTRADAY=
LLM_PROVIDER_SCALP=
LLM_MODEL_SCALP=

# === MACRO DATA (optional — có thể skip cho MVP) ===
# FRED: fred.stlouisfed.org/docs/api/api_key (free)
FRED_API_KEY=
# NewsAPI: newsapi.org/register (free 100 req/day)
NEWS_API_KEY=

# === BOT SETTINGS ===
# LUÔN bắt đầu bằng PAPER_TRADE=true trước khi lên live
PAPER_TRADE=true
# swing | intraday | scalp
TRADING_MODE=swing
# false = chỉ bắn signal Telegram, không tự đặt lệnh
AUTO_TRADE=false
# true = chỉ in signal ra console, không ghi DB và không gửi Telegram
DRY_RUN=false

# === DB & LOG ===
DB_PATH=data/bot.db
LOG_LEVEL=INFO

# === HEALTH CHECK ===
HEALTH_VERBOSE=false
HEALTH_INTERVAL_MIN=5
HEALTH_ALERT_AFTER_MIN=15

# === COST CONTROLS ===
LLM_DAILY_BUDGET_USD=5.0
MIN_POSITION_USD=10
